# 飞书应用凭证
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# 测试环境配置
TEST_APP_TOKEN=your_test_app_token
TEST_TABLE_ID=your_test_table_id
TEST_INDEX_FIELD_NAME=索引

# 生产环境配置
PROD_APP_TOKEN=your_prod_app_token
PROD_TABLE_ID=your_prod_table_id
PROD_INDEX_FIELD_NAME=索引

# CORS配置（可选，默认允许所有来源；生产环境建议配置具体域名）
# CORS_ORIGINS=http://localhost:3001,http://localhost:5173
